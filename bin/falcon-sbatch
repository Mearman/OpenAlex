#!/usr/bin/env bash
# falcon-sbatch: submit Slurm jobs on Falcon from the local machine.
#
# Usage: falcon-sbatch <local-script> [-- <extra-ssh-args>]
#
# Idempotent: deploys the script to Falcon, then runs sbatch-idem.
# If a job with the same --job-name is already pending/running and
# the script hasn't changed, skips submission.
#
# Uses a SINGLE SSH connection (piping stdin for the script deploy,
# then running sbatch-idem) to avoid Tailscale userspace-networking
# issues with rapid sequential connections.
#
# SSH routing (tried in order):
#   1. FALCON_SSH env var (explicit override)
#   2. Tailscale direct (ssh falcon)
#   3. BU jump host (bangor-gateway → falconlogin.cf.ac.uk)

set -euo pipefail

SCRIPT="${1:?Usage: $0 <local-script> [-- <extra-ssh-args>]}"
shift

SSH_ARGS=()
if [ "${1:-}" = "--" ]; then
    shift
    SSH_ARGS=("$@")
fi

if [ ! -f "$SCRIPT" ]; then
    echo "Error: $SCRIPT not found" >&2
    exit 2
fi

REMOTE_BASE="/scratch/SCWF00070/b.abs217"
BASENAME=$(basename "$SCRIPT")
REMOTE_SCRIPT="$REMOTE_BASE/$BASENAME"

# Detect route
if [ -n "${FALCON_SSH:-}" ]; then
    ROUTE="override"
elif timeout 3 ssh -o ConnectTimeout=2 falcon true 2>/dev/null; then
    ROUTE="tailscale"
else
    ROUTE="jumphost"
fi

# Build the SSH connection string
if [ "$ROUTE" = "tailscale" ]; then
    SSH=(ssh "${SSH_ARGS[@]}" -o ConnectTimeout=5 falcon)
elif [ "$ROUTE" = "jumphost" ]; then
    SSH=(ssh "${SSH_ARGS[@]}" -o ConnectTimeout=10 \
         -o ProxyCommand="ssh -o ConnectTimeout=10 bangor-gateway -W %h:%p" \
         b.abs217@falconlogin.cf.ac.uk)
else
    # Override — try tailscale first, then jumphost
    SSH=(ssh "${SSH_ARGS[@]}" -o ConnectTimeout=5 falcon)
fi

echo "[$ROUTE] $BASENAME → $REMOTE_SCRIPT"

# Deploy script via stdin, then run sbatch-idem — single connection
"${SSH[@]}" "cat > '$REMOTE_SCRIPT' && bash \$HOME/.local/bin/sbatch-idem '$REMOTE_SCRIPT'" < "$SCRIPT"
