#!/usr/bin/env bash
# Pre-commit hook: validate, type-check, and lint staged Python files.
# - ruff: lint errors (blocking)
# - mypy: type errors in ci_sync.py (blocking)
# - perflint: performance warnings (advisory, non-blocking)

cd "$(git rev-parse --show-toplevel)"

STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -z "$STAGED_PY" ]; then
  echo "pre-commit: no Python files changed, skipping."
  exit 0
fi

echo "pre-commit: $(echo "$STAGED_PY" | wc -l | tr -d ' ') file(s)"

if echo "$STAGED_PY" | grep -q 'ci_sync\.py'; then
  echo "--- ruff ---"
  python3 -m ruff check sync/ci_sync.py

  echo "--- mypy ---"
  python3 -m mypy sync/ci_sync.py --follow-imports=skip --no-error-summary \
    --disable-error-code=import-untyped

  echo "--- perflint ---"
  python3 -m perflint sync/ci_sync.py || true
fi

echo "pre-commit: OK"
